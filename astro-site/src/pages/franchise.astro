<script>
var navToggle = document.querySelector('.nav-toggle');
var navLinks = document.querySelector('.nav-links');
if (navToggle && navLinks) {
  navToggle.addEventListener('click', function(){
    var open = navLinks.classList.toggle('open');
    navToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
  });
  navLinks.querySelectorAll('a').forEach(function(link){
    link.addEventListener('click', function(){
      navLinks.classList.remove('open');
      navToggle.setAttribute('aria-expanded', 'false');
    });
  });
}
function submitForm(e) {
  e.preventDefault();
  var f = e.target;
  var data = new FormData(f);
  var info = '';
  data.forEach(function(v,k){ info += k + ': ' + v + '\n'; });
  f.style.display = 'none';
  document.getElementById('formSuccess').style.display = 'block';
}

var franchiseAnswers = [
  {keys:['cost','investment','startup','open'],answer:'A standard Pizza World store is currently presented around $138K–$286K estimated startup cost. The C-Store concept is shown around $92K–$232K. The initial franchise fee is listed as $19,500. Final costs depend on site, size, buildout, equipment, market, and the official franchise documents.'},
  {keys:['royalty','royalties','marketing fee','fees','fee'],answer:'Pizza World promotes a 2.75% royalty on net sales and no required marketing fund contribution. Franchisees still need to invest in local marketing for their own market. Official documents control final fee obligations.'},
  {keys:['training','support','help','operations'],answer:'Training includes a virtual training program before store training, about two weeks of hands-on training at a designated Pizza World location, opening support, operational guidance, approved specs, marketing resources, and ongoing access to training materials for new employees.'},
  {keys:['long','timeline','time','construction','open'],answer:'Construction is typically presented around 90–120 days depending on location, store format, permits, buildout, equipment, and readiness. Site selection, lease timing, financing, and construction approvals can affect the timeline.'},
  {keys:['experience','restaurant','ownership','background'],answer:'Restaurant experience can help, but the opportunity is designed around training, systems, and support. The stronger questions are whether the candidate has the right capital, work ethic, leadership ability, and willingness to follow the Pizza World system.'},
  {keys:['territory','market','available','city','state','area'],answer:'Territories are available in select markets. Availability depends on the target area, current development plans, and Pizza World approval. A franchise representative would confirm whether a specific city or territory is open.'},
  {keys:['equipment','supplier','suppliers','buildout'],answer:'Pizza World provides buildout guidance, equipment specifications, approved supplier direction, and system standards. Franchisees may be required to use designated or approved suppliers so stores stay consistent with brand standards.'},
  {keys:['financing','sba','loan','bank'],answer:'Pizza World is presented as SBA approved, so qualified candidates may be able to pursue SBA financing through participating lenders. Financing depends on the applicant, lender, credit, capital, and full project scope.'},
  {keys:['request','info','apply','contact','call','representative','next step'],answer:'Great — the next step is to share your name, contact info, market of interest, timeline, available capital range, and any restaurant/business experience. I can help prepare that inquiry now.'}
];
function addChatMessage(text, who){
  var chat = document.getElementById('chatWindow');
  if(!chat) return;
  var msg = document.createElement('div');
  msg.className = 'chat-message ' + (who || 'bot');
  var bubble = document.createElement('div');
  bubble.className = 'bubble';
  bubble.textContent = text;
  msg.appendChild(bubble);
  chat.appendChild(msg);
  chat.scrollTop = chat.scrollHeight;
}
function getAssistantAnswer(question){
  var q = String(question || '').toLowerCase();
  for(var i=0;i<franchiseAnswers.length;i++){
    if(franchiseAnswers[i].keys.some(function(k){ return q.indexOf(k) !== -1; })) return franchiseAnswers[i].answer;
  }
  return 'Good question. I can help with general franchise topics like investment, royalties, training, support, opening timeline, territories, financing, equipment, and next steps. For exact legal or territory details, a Pizza World franchise representative should confirm from the official documents.';
}
function askAssistant(question){
  if(!question || !question.trim()) return;
  addChatMessage(question.trim(), 'user');
  window.setTimeout(function(){
    var answer = getAssistantAnswer(question);
    addChatMessage(answer, 'bot');
    if(/request|info|apply|contact|call|representative|next step/i.test(question)){
      var lead = document.getElementById('leadCapture');
      if(lead) lead.classList.add('open');
    }
  }, 250);
}
var assistantForm = document.getElementById('assistantForm');
var assistantInput = document.getElementById('assistantInput');
if(assistantForm && assistantInput){
  assistantForm.addEventListener('submit', function(e){
    e.preventDefault();
    var q = assistantInput.value;
    assistantInput.value = '';
    askAssistant(q);
  });
}
document.querySelectorAll('#quickPrompts button').forEach(function(btn){
  btn.addEventListener('click', function(){ askAssistant(btn.getAttribute('data-question')); });
});
var floatingAssistant = document.getElementById('floatingAssistant');
if(floatingAssistant){
  floatingAssistant.addEventListener('click', function(){
    document.getElementById('franchise-assistant').scrollIntoView({behavior:'smooth',block:'start'});
    window.setTimeout(function(){ if(assistantInput) assistantInput.focus(); }, 550);
  });
}
var leadSubmit = document.getElementById('leadSubmit');
if(leadSubmit){
  leadSubmit.addEventListener('click', function(){
    var summary = 'Franchise inquiry prepared: ' +
      (document.getElementById('leadName').value || 'Name not provided') + ' | ' +
      (document.getElementById('leadPhone').value || 'Phone not provided') + ' | ' +
      (document.getElementById('leadEmail').value || 'Email not provided') + ' | Market: ' +
      (document.getElementById('leadMarket').value || 'Not provided') + ' | Capital: ' +
      (document.getElementById('leadCapital').value || 'Not provided') + '. Please submit the main form below or call (417) 730-1177.';
    addChatMessage(summary, 'bot');
    document.getElementById('contact').scrollIntoView({behavior:'smooth',block:'start'});
  });
}
</script>
