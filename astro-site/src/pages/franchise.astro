        <button type="button" data-question="Do I need restaurant experience?">Experience needed?</button>
        <button type="button" data-question="I want to request franchise information.">Request info</button>
      </div>
      <form class="assistant-input" id="assistantForm">
        <input id="assistantInput" type="text" placeholder="Ask about the franchise opportunity..." autocomplete="off">
        <button type="submit">Ask</button>
      </form>
      <div class="lead-capture" id="leadCapture">
        <h3>Send My Franchise Info</h3>
        <p>Share a few details and our franchise team can follow up with the right information for your market.</p>
        <div class="lead-capture-grid">
          <input id="leadName" placeholder="Name">
          <input id="leadPhone" placeholder="Phone">
          <input id="leadEmail" class="full" placeholder="Email">
          <input id="leadMarket" placeholder="City / State of interest">
          <select id="leadCapital"><option value="">Available capital</option><option>Under $100K</option><option>$100K – $200K</option><option>$200K – $300K</option><option>$300K+</option></select>
          <button class="full" type="button" id="leadSubmit">Prepare Inquiry</button>
        </div>
      </div>
      <div class="assistant-disclaimer">General information only. Franchise terms, fees, territories, and requirements may vary and are controlled by the official Franchise Disclosure Document and franchise agreement.</div>
    </div>
  </div>
</section>
<button class="floating-assistant" type="button" id="floatingAssistant">Ask Franchise Questions</button>

